# .dockerignore

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
.eggs/

# Virtual environment — never copy this
venv/
.venv/
env/

# Development files
.git/
.gitignore
*.md
notebooks/

# Large data files — mounted as volumes instead
data/raw/
data/charts/

# Environment files — never bake secrets into images
.env
.env.*

# Frontend — has its own build process
frontend/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db