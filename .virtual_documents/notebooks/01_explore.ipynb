import yfinance as yf
import pandas as pd
import matplotlib.pyplot as plt
import sys
import os


sys.path.append("..")
os.makedirs("../data/charts", exist_ok=True)


from src.data.fetch import fetch_stock_data


df=fetch_stock_data("RELIANCE.NS",period="1y")


fig,(ax1,ax2)=plt.subplots(2,1,figsize=(14,8),gridspec_kw={"height_ratios" : [3,1]})


ax1.plot(df.index,df["Close"],color="#2196F3", linewidth=1.5, label="Close price")
ax1.set_title("Reliance Industries — 1 Year", fontsize=14)
ax1.set_ylabel("Price (INR)")
ax1.legend()
ax1.grid(alpha=0.3)


ax2.bar(df.index, df["Volume"], color="#90CAF9", alpha=0.7)
ax2.set_ylabel("Volume")
ax2.grid(alpha=0.3)



fig.tight_layout()
fig.savefig(
    "../data/charts/reliance_1y.png",
    dpi=150
)
plt.show()




